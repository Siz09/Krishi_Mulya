# Krishi Mulya — Environment Variables
# Copy this file to web/.env.local and fill in real values.
# Never commit .env.local or .env to git.

# ─── Supabase (public — safe for browser) ──────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Supabase (server-only) ─────────────────────────────────────────────────
# SUPABASE_URL is the same value as NEXT_PUBLIC_SUPABASE_URL
# but named without the prefix so it's never bundled client-side.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Vercel Cron auth ───────────────────────────────────────────────────────
# A random secret string — set this in Vercel Project Settings too.
CRON_SECRET=

# ─── Sparrow SMS (Phase 2 — Alerts) ─────────────────────────────────────────
SPARROW_SMS_TOKEN=
SPARROW_SMS_FROM=
